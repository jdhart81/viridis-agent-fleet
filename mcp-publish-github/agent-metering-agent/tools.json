          },
          "outcome": {
            "default": "ok",
            "title": "Outcome",
            "type": "string"
          },
          "metadata": {
            "anyOf": [
              {
                "additionalProperties": true,
                "type": "object"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Metadata"
          }
        },
        "required": [
          "meter_id",
          "event_id",
          "quantity"
        ],
        "title": "record_usageArguments",
        "type": "object"
      }
    },
