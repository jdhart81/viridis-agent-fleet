{
  "server": "agent-metering-agent",
  "tool_count": 11,
  "tools": [
    {
      "name": "create_meter",
      "description": "Create a usage meter between a provider and a consumer agent.\n\n    unit: what is being counted (call, token, kwh, ...). Price is in minor\n    currency units (cents) per unit. Returns the meter_id.",
      "inputSchema": {
        "properties": {
          "provider": {
            "title": "Provider",
            "type": "string"
          },
          "consumer": {
            "title": "Consumer",
            "type": "string"
          },
          "unit": {
            "title": "Unit",
            "type": "string"
          },
          "price_minor_per_unit": {
            "title": "Price Minor Per Unit",
            "type": "number"
          },
          "currency": {
            "default": "USD",
            "title": "Currency",
            "type": "string"
          },
          "sla_target": {
            "default": 0.99,
            "title": "Sla Target",
            "type": "number"
          }
        },
        "required": [
          "provider",
          "consumer",
          "unit",
          "price_minor_per_unit"
        ],
        "title": "create_meterArguments",
        "type": "object"
      }
    },
    {
      "name": "record_usage",
