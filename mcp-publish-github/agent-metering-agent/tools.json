{
  "server": "agent-metering-agent",
  "tool_count": 11,
  "tools": [
    {
      "name": "create_meter",
      "description": "Create a usage meter between a provider and a consumer agent.\n\nunit: what is being counted (call, token, kwh, ...). Price is in minor\ncurrency units (cents) per unit. Returns the meter_id.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "provider": {
            "type": "string"
          },
          "consumer": {
            "type": "string"
          },
          "unit": {
            "type": "string"
          },
          "price_minor_per_unit": {
            "type": "number"
          },
          "currency": {
            "type": "string",
            "default": "USD"
          },
          "sla_target": {
            "type": "number",
            "default": 0.99
          }
        },
        "required": [
          "provider",
          "consumer",
          "unit",
          "price_minor_per_unit"
        ]
      }
    },
    {
      "name": "record_usage",
      "description": "Record a usage event. Idempotent on event_id (safe to retry \u2014 never\ndouble-billed). outcome is 'ok' or 'error' and feeds the SLA report.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "meter_id": {
            "type": "string"
          },
          "event_id": {
            "type": "string"
          },
          "quantity": {
            "type": "number"
          },
          "outcome": {
            "type": "string",
            "default": "ok"
          },
          "metadata": {
            "type": "object"
          }
        },
        "required": [
          "meter_id",
          "event_id",
          "quantity"
        ]
      }
    },
    {
      "name": "usage_summary",
      "description": "Totals for a meter: event count, total quantity, accrued minor units.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "meter_id": {
            "type": "string"
          }
        },
        "required": [
          "meter_id"
        ]
      }
    },
    {
      "name": "sla_report",
      "description": "Pure SLA report: success_rate vs sla_target, breach flag. No mutation.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "meter_id": {
            "type": "string"
          }
        },
        "required": [
          "meter_id"
        ]
      }
    },
    {
      "name": "close_period",
      "description": "Freeze all open events into an immutable invoice (exactly-once).\nThe invoice amount is what agent-escrow-agent should settle.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "meter_id": {
            "type": "string"
          }
        },
        "required": [
          "meter_id"
        ]
      }
    },
    {
      "name": "verify_chain",
      "description": "Verify the tamper-evident event hash chain for a meter.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "meter_id": {
            "type": "string"
          }
        },
        "required": [
          "meter_id"
        ]
      }
    },
    {
      "name": "list_meters",
      "description": "List all meters with event/invoice counts.",
      "inputSchema": {
        "type": "object",
        "properties": {},
        "required": []
      }
    },
    {
      "name": "list_events",
      "description": "Read usage events (paginated, read-only). Filter by meter, provider,\nconsumer_class (internal|external|unknown), channel, outcome (ok|error),\nand ISO date range [since, until). Test-flagged events are excluded\nunless include_test=true. Returns events + next_cursor.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "meter_id": {
            "type": "string"
          },
          "provider": {
            "type": "string"
          },
          "consumer_class": {
            "type": "string"
          },
          "channel": {
            "type": "string"
          },
          "outcome": {
            "type": "string"
          },
          "since": {
            "type": "string"
          },
          "until": {
            "type": "string"
          },
          "include_test": {
            "type": "boolean",
            "default": false
          },
          "limit": {
            "type": "integer",
            "default": 100
          },
          "cursor": {
            "type": "string"
          }
        },
        "required": []
      }
    },
    {
      "name": "usage_timeseries",
      "description": "Usage time series bucketed on each event's recorded_at (UTC;\nbucket=day|hour), grouped across meters by provider \u2014 a real time-series\nprimitive, independent of meter creation times. Includes per-bucket\nbreakdowns by consumer_class / channel / provider. est_accrued_minor is\nan estimate; authoritative billing stays with usage_summary.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "bucket": {
            "type": "string",
            "default": "day"
          },
          "provider": {
            "type": "string"
          },
          "meter_id": {
            "type": "string"
          },
          "consumer_class": {
            "type": "string"
          },
          "channel": {
            "type": "string"
          },
          "since": {
            "type": "string"
          },
          "until": {
            "type": "string"
          },
          "include_test": {
            "type": "boolean",
            "default": false
          }
        },
        "required": []
      }
    },
    {
      "name": "flag_meter",
      "description": "Admin: flag/unflag a meter as test/synthetic so its events are\nexcluded from usage statistics by default. Touches meter metadata only \u2014\nnever events, never the hash chain, never billing accruals. Requires the\nserver's VIRIDIS_ADMIN_TOKEN.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "meter_id": {
            "type": "string"
          },
          "is_test": {
            "type": "boolean"
          },
          "admin_token": {
            "type": "string"
          },
          "note": {
            "type": "string",
            "default": ""
          }
        },
        "required": [
          "meter_id",
          "is_test",
          "admin_token"
        ]
      }
    },
    {
      "name": "describe_agent",
      "description": "Fleet-standard self-description.",
      "inputSchema": {
        "type": "object",
        "properties": {},
        "required": []
      }
    }
  ]
}
